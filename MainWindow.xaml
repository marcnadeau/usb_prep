<Window x:Class="MediaFileAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Audio File Analyzer &amp; FLAC Converter" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="20,15">
            <TextBlock Text="Audio File Analyzer &amp; FLAC to MP3 Converter" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="White"/>
        </Border>

        <!-- Folder Selection -->
        <Border Grid.Row="1" Padding="20" Background="#ECF0F1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="Folder:" 
                           VerticalAlignment="Center" 
                           FontWeight="Bold" 
                           Margin="0,0,10,0"/>
                
                <TextBox Grid.Column="1" 
                         x:Name="FolderPathTextBox" 
                         VerticalAlignment="Center" 
                         Padding="8" 
                         IsReadOnly="True"
                         FontSize="14"
                         Background="White"/>
                
                <Button Grid.Column="2" 
                        Content="Browse..." 
                        Click="BrowseButton_Click" 
                        Padding="15,8" 
                        Margin="10,0,0,0"
                        FontSize="14"
                        Background="#3498DB"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>
                
                <Button Grid.Column="3" 
                        Content="Scan" 
                        Click="ScanButton_Click" 
                        Padding="15,8" 
                        Margin="10,0,0,0"
                        FontSize="14"
                        FontWeight="Bold"
                        Background="#27AE60"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        IsEnabled="{Binding ElementName=FolderPathTextBox, Path=Text.Length}"/>
            </Grid>
        </Border>

        <!-- Convert Button Row -->
        <Border Grid.Row="2" Padding="20" Background="#ECF0F1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button x:Name="ConvertButton"
                            Content="Convert FLAC to MP3 (320kbps)"
                            Click="ConvertButton_Click"
                            Padding="15,10"
                            FontSize="14"
                            FontWeight="Bold"
                            Background="#E74C3C"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Visibility="Collapsed"/>
                    <Button x:Name="RenameButton"
                            Content="Rename All Files (Picard)"
                            Click="RenameButton_Click"
                            Padding="15,10"
                            Margin="10,0,0,0"
                            FontSize="14"
                            FontWeight="Bold"
                            Background="#9B59B6"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Visibility="Collapsed"/>
                    <TextBlock Margin="15,0,0,0"
                               VerticalAlignment="Center"
                               Text="Rename files to follow Picard naming convention (Artist/Album/TrackNumber - Title)"
                               Foreground="#555"
                               FontStyle="Italic"/>
                </StackPanel>
                
                <TextBlock Grid.Column="1"
                           x:Name="ProgressCountText"
                           Text=""
                           VerticalAlignment="Center"
                           Foreground="#333"
                           FontWeight="Bold"
                           Margin="20,0,0,0"/>
            </Grid>
        </Border>

        <!-- Progress Bar -->
        <Border Grid.Row="2" Padding="20" Background="#ECF0F1" Visibility="Collapsed" x:Name="ProgressBorder">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0"
                           x:Name="ProgressStatusText"
                           Text="Converting FLAC files..."
                           Foreground="#333"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>
                
                <ProgressBar Grid.Row="1"
                             x:Name="ConversionProgressBar"
                             Height="25"
                             Foreground="#27AE60"
                             Background="#DDD"
                             Value="0"
                             Maximum="100"
                             Margin="0,0,0,10"/>
                
                <TextBlock Grid.Row="2"
                           x:Name="CurrentFileText"
                           Text=""
                           Foreground="#555"
                           FontSize="12"
                           TextAlignment="Center"/>

                <Button Grid.Row="3"
                    x:Name="StopButton"
                    Content="Stop"
                    Click="StopButton_Click"
                    Padding="14,8"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    Background="#C0392B"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"
                    Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- Results Area -->
        <Grid Grid.Row="4" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Statistics Panel -->
            <Border Grid.Row="0" 
                    Background="#3498DB" 
                    Padding="15" 
                    Margin="0,0,0,10"
                    CornerRadius="5">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <StackPanel Margin="0,0,40,0">
                        <TextBlock Text="Total Files" 
                                   Foreground="White" 
                                   FontSize="12" 
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="TotalFilesText" 
                                   Text="0" 
                                   Foreground="White" 
                                   FontSize="24" 
                                   FontWeight="Bold" 
                                   TextAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,40,0">
                        <TextBlock Text="MP3 Files" 
                                   Foreground="White" 
                                   FontSize="12" 
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="ImageCountText" 
                                   Text="0" 
                                   Foreground="White" 
                                   FontSize="24" 
                                   FontWeight="Bold" 
                                   TextAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,40,0">
                        <TextBlock Text="FLAC Files" 
                                   Foreground="White" 
                                   FontSize="12" 
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="VideoCountText" 
                                   Text="0" 
                                   Foreground="White" 
                                   FontSize="24" 
                                   FontWeight="Bold" 
                                   TextAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel>
                        <TextBlock Text="Total Size" 
                                   Foreground="White" 
                                   FontSize="12" 
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="TotalSizeText" 
                                   Text="0 MB" 
                                   Foreground="White" 
                                   FontSize="24" 
                                   FontWeight="Bold" 
                                   TextAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- File List -->
            <DataGrid Grid.Row="1" 
                      x:Name="FilesDataGrid" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      AlternatingRowBackground="#F8F9FA"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      CanUserResizeRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*" MinWidth="200"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding FileType}" Width="80"/>
                    <DataGridTextColumn Header="Format" Binding="{Binding Format}" Width="100"/>
                    <DataGridTextColumn Header="Size" Binding="{Binding FileSize}" Width="100"/>
                    <DataGridTextColumn Header="Path" Binding="{Binding FilePath}" Width="*" MinWidth="200"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="5" Background="#34495E" Padding="10">
            <TextBlock x:Name="StatusText" 
                       Text="Ready to scan. Select a folder to begin." 
                       Foreground="White"
                       FontSize="12"/>
        </Border>
    </Grid>
</Window>
